{
    "pythonVersion": "3.14",
    "pythonPlatform": "Windows",
    "venvPath": ".",
    "include": [
        "src",
        "anno"
    ],
    "exclude": [
        "**/node_modules",
        "**/.*/",
        "**/.*",
        "**/__pycache__",
        "**/logs"
    ],
    "typeCheckingMode": "basic",
    "reportMissingModuleSource": "none",
    "reportMissingTypeStubs": "none",
    "executionEnvironments": [
        {
            "root": "src"
        },
        {
            "root": "anno"
        }
    ]
}
