# FocusGuard 환경 변수 설정 예시
# 이 파일을 복사하여 .env 로 저장한 뒤 값을 수정하세요.
# cp .env.example .env

# ── 해제 요청 ────────────────────────────────────
# 클라우드 승인 대기 타임아웃 (초)
UNLOCK_CODE_TTL=120

# ── 기능 플래그 ──────────────────────────────────
# 오버레이 활성화 중 키보드 전체 차단 여부
KEYBOARD_BLOCK_ENABLED=false
# 클라우드 LLM 사용 여부 (true 시 CloudLLMClient 사용)
USE_CLOUD_LLM=false

# ── Ollama ───────────────────────────────────────
# Ollama API 서버 주소
OLLAMA_HOST=http://localhost:11434
# 사용할 Ollama 모델명
OLLAMA_MODEL=gemma3:4b
# Ollama API 응답 타임아웃 (초)
LLM_TIMEOUT=60

# ── 클라우드 API (Phase 2) ────────────────────────
# API Gateway 기본 URL (빈 값이면 원격 전송 비활성, 로컬 JSONL만 사용)
# 예: https://xxxxxxxxxx.execute-api.ap-northeast-2.amazonaws.com
CLOUD_API_URL=
# RemoteSink HTTP 타임아웃 (초)
REMOTE_SINK_TIMEOUT=5
# EC2 Ollama 서버 주소 (USE_CLOUD_LLM=true 시 필수)
# SSH 터널 사용 시: ssh -i key.pem -L 11434:localhost:11434 ubuntu@<EC2-IP> -N → http://localhost:11434
# 직접 연결 시: http://ec2-xx-xx-xx-xx.ap-northeast-2.compute.amazonaws.com:11434
CLOUD_LLM_HOST=
