# FocusGuard 환경 변수 설정 예시
# 이 파일을 복사하여 .env 로 저장한 뒤 값을 수정하세요.
# cp .env.example .env

# ── HTTP 서버 ────────────────────────────────────
# 해제 인증 페이지를 제공하는 HTTP 서버 포트
WEB_AUTH_PORT=8080

# ── 해제 코드 ────────────────────────────────────
# 해제 코드 유효 시간 (초)
UNLOCK_CODE_TTL=120
# 해제 코드 자릿수 (4~12)
UNLOCK_CODE_LENGTH=6
# 연속 실패 허용 횟수 (초과 시 코드 무효화)
UNLOCK_MAX_FAILED_ATTEMPTS=5

# ── 기능 플래그 ──────────────────────────────────
# 오버레이 활성화 중 키보드 전체 차단 여부
KEYBOARD_BLOCK_ENABLED=false
# 클라우드 LLM 사용 여부 (true 시 CloudLLMClient 사용)
USE_CLOUD_LLM=false

# ── Ollama ───────────────────────────────────────
# Ollama API 서버 주소
OLLAMA_HOST=http://localhost:11434
# 사용할 Ollama 모델명
OLLAMA_MODEL=gemma3:4b
# Ollama API 응답 타임아웃 (초)
LLM_TIMEOUT=60
